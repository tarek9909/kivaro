CORS_ORIGIN=*
REQUEST_BODY_LIMIT=1mb

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

OWNER_FULL_NAME=System Owner
