NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=charcoal_erp
DB_USER=root
DB_PASSWORD=mysql
DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT_MS=2000
REQUIRE_DB_ON_STARTUP=false

